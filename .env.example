# --- Azure AI Search ---------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_VERSION=2026-05-01-preview
RESOURCE_PREFIX=sharepoint

# --- Azure OpenAI (text embeddings + verbalization chat) ---------------------
AZURE_OPENAI_ENDPOINT=https://<your-foundry>.openai.azure.com/
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_GPT_MODEL=gpt-4.1-mini

# --- Azure AI Services / Foundry (Content Understanding + Azure AI Vision) ----
AZURE_AI_SERVICES_ENDPOINT=https://<your-foundry>.cognitiveservices.azure.com/
AZURE_AI_VISION_MODEL_VERSION=2023-04-15

# --- Infra outputs for Phase 2/3 (app registration + role grants). Not secrets. ---
# Written by scripts/deploy-infra.ps1; consumed by the admin for setup-app-registration.ps1
# and grant-dev-and-managed-identity.ps1.
AZURE_SEARCH_IDENTITY_PRINCIPAL_ID=<search service system-assigned MI principalId>
AZURE_FOUNDRY_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<foundry>
AZURE_SEARCH_SERVICE_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Search/searchServices/<search>

# --- SharePoint data source (produced by scripts/setup-app-registration.ps1) --
SHAREPOINT_CONNECTION_STRING=SharePointOnlineEndpoint=https://<tenant>.sharepoint.com/sites/<site>;ApplicationId=<appId>;ApplicationSecret=<secret>;TenantId=<tenantId>
SHAREPOINT_CONTAINER_NAME=defaultSiteLibrary
SP_APP_CLIENT_ID=<appId>
SP_TENANT_ID=<tenantId>
